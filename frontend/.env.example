# Base URL of the Service Marketplace backend.
# Local dev (Spring on :8080):   http://localhost:8080
# Live (Render free tier):       https://marketplace-api-kehz.onrender.com
# Note: any var prefixed with NEXT_PUBLIC_ is inlined into the client bundle.
NEXT_PUBLIC_API_BASE_URL=

# Stripe PUBLISHABLE key (test mode). Safe to ship to the browser — it can only
# create tokens/PaymentIntents client-side, never charge or read sensitive data.
# Get it from the Stripe Dashboard → Developers → API keys → "Publishable key"
# (starts with pk_test_... in test mode). The matching SECRET key (sk_test_...)
# lives ONLY on the backend — never put it here.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
