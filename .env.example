# Environment variables for local development
# Copy this file to .env and fill in values
# .env is gitignored — never commit real credentials

POSTGRES_USER=marketplace
POSTGRES_PASSWORD=marketplace
POSTGRES_DB=marketplace

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/marketplace
SPRING_DATASOURCE_USERNAME=marketplace
SPRING_DATASOURCE_PASSWORD=marketplace

# Redis Configuration (Phase 5 — caching + rate limiting)
# Matches docker-compose.yml (marketplace-redis on port 6379).
# Optional: omit to fall back to application-dev.yml defaults (localhost:6379).
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
# SPRING_DATA_REDIS_PASSWORD=  # Uncomment if your Redis requires AUTH

# Stripe Configuration (Phase 4)
# Get test API key from: https://dashboard.stripe.com/test/apikeys
# Get webhook secret from Stripe CLI: stripe listen --print-secret
STRIPE_API_KEY=sk_test_your_stripe_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Admin bootstrap (Phase 5.5 — vendor approval)
# Optional: set BOTH to seed an ADMIN user on startup so /api/admin/** can be used.
# If either is unset, no admin is seeded (the app still starts). Never hardcode a real password in
# code/migrations — these env vars are the only place the bootstrap reads credentials from.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-password

# JWT signing secret (Phase 6 Slice 3 — prod profile).
# REQUIRED when SPRING_PROFILES_ACTIVE=prod (no default in application-prod.yml → fail-fast if unset).
# HS256 needs >=256-bit (>=32-char) keys. Generate a real one for prod, e.g.:
#   openssl rand -base64 48
JWT_SECRET=change-this-to-a-256-bit-secret-at-least-32-chars

# CORS allow-list (Phase 7 — frontend).
# Comma-separated browser origins allowed to call the API. Wildcards work via Spring's
# origin-pattern syntax. Empty (default) = no cross-origin browser requests (fail-closed).
# Local Next.js dev runs on http://localhost:3000; set this to match your frontend origin.
# Example: http://localhost:3000,https://service-marketplace.vercel.app,https://*.vercel.app
APP_CORS_ALLOWED_ORIGINS=
