# Environment variables for local development
# Copy this file to .env and fill in values
# .env is gitignored — never commit real credentials

POSTGRES_USER=marketplace
POSTGRES_PASSWORD=marketplace
POSTGRES_DB=marketplace

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/marketplace
SPRING_DATASOURCE_USERNAME=marketplace
SPRING_DATASOURCE_PASSWORD=marketplace

# Redis Configuration (Phase 5 — caching + rate limiting)
# Matches docker-compose.yml (marketplace-redis on port 6379).
# Optional: omit to fall back to application-dev.yml defaults (localhost:6379).
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  # Uncomment if your Redis requires AUTH

# Stripe Configuration (Phase 4)
# Get test API key from: https://dashboard.stripe.com/test/apikeys
# Get webhook secret from Stripe CLI: stripe listen --print-secret
STRIPE_API_KEY=sk_test_your_stripe_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
